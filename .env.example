NODE_ENV=development
PORT=3000
SERVICE_NAME=salidia-api
LOG_LEVEL=log

DATABASE_ENABLED=true
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=salidia
DATABASE_USER=salidia
DATABASE_PASSWORD=change-me-local-only
DATABASE_SSL=false
DATABASE_LOGGING=false

JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=salidia-api
JWT_AUDIENCE=salidia

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
