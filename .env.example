NODE_ENV=development
PORT=3004
SERVICE_NAME=regihora-api
LOG_LEVEL=log

DATABASE_ENABLED=true
DATABASE_HOST=localhost
DATABASE_PORT=5436
DATABASE_NAME=regihora
DATABASE_USER=regihora
DATABASE_PASSWORD=change-me-local-only
DATABASE_SSL=false
DATABASE_LOGGING=false

JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
JWT_ISSUER=regihora-api
JWT_AUDIENCE=regihora
# Public Web OAuth client ID served by /v1/auth/config and used to verify Google ID tokens.
GOOGLE_OAUTH_CLIENT_ID=

CORS_ALLOWED_ORIGINS=http://localhost:4204,http://127.0.0.1:4204,http://localhost:4304,http://127.0.0.1:4304
WEBAPP_BASE_URL=http://localhost:4204

EMPLOYEE_INVITATION_TTL_HOURS=168
EMAIL_DELIVERY_MODE=log
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENTIAL=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
